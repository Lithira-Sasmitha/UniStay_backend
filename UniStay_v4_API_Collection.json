		{
			"name": "02. SuperAdmin Roles",
			"item": [
				{
					"name": "Update User Role",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"boardingowner\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/users/:id/role",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								":id",
								"role"
							],
							"variable": [
								{
									"key": "id",
									"value": "USER_ID_HERE"
								}
							]
						},
						"description": "Only accessible by superadmin. Changes any user's role."
					},
					"response": []
				}
			]
		},
