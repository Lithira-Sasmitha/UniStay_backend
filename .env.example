PORT=5000
MONGODB_URI=mongodb://localhost:27017/unistay
NODE_ENV=development

# JWT Secrets
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
JWT_SECRET=

# CORS (comma-separated origins, defaults to localhost:5173,localhost:3000)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cloudinary (optional — falls back to memory storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (optional — payment features disabled without it)
STRIPE_SECRET_KEY=

# Email (Brevo SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (for email links)
CLIENT_URL=http://localhost:5173

# Seed Admin (optional — defaults to superadmin@unistay.com / superadmin)
SEED_ADMIN_EMAIL=
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
